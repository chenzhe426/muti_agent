# ==================== 生产环境配置 ====================
# 复制此文件为 .env 并修改相应值

# ==================== LLM 配置 ====================
# 提供商: openai | vllm | ollama | tgi
LLM_PROVIDER=vllm

# vLLM 集群代理地址 (通过 Nginx 负载均衡)
LLM_BASE_URL=http://localhost:8002/v1

# 模型名称 (需提前下载到 ./models 目录)
LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# 最大并发数 (根据 vLLM 实例数调整)
LLM_MAX_CONCURRENT=10

# ==================== Redis 配置 (多 Worker 共享状态) ====================
# 状态存储类型: memory | redis
CHECKPOINTER_TYPE=redis

# Redis 连接地址
REDIS_URL=redis://localhost:6379

# Redis 连接池大小 (建议: worker数 * 10)
REDIS_MAX_CONNECTIONS=50

# Redis 线程数
REDIS_THREAD_COUNT=10

# ==================== 向量数据库 ====================
QDRANT_URL=http://localhost:6333

# ==================== 日志 ====================
LOG_LEVEL=INFO

RECREATE_COLLECTIONS=False

# ==================== LangSmith (可选，用于追踪) ====================
LANGCHAIN_TRACING_V2=false
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
# LANGCHAIN_API_KEY=your-api-key
# LANGCHAIN_PROJECT=your-project
